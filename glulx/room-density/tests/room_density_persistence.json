{
  "timeout_seconds": 45,
  "allowed_exit_codes": [0],
  "close_stdin": false,
  "steps": [
    {"expect": "Release 1218"},
    {"sendline": "rdtroll"},
    {"expect": "ROOM-DENSITY-SETUP:TROLL"},
    {"sendline": "examine blood"},
    {"expect": "old bloodstains have soaked into cracks"},
    {"sendline": "rdgallery"},
    {"expect": "ROOM-DENSITY-SETUP:GALLERY"},
    {"sendline": "examine paintings"},
    {"expect": "A few paintings remain"},
    {"sendline": "rdstudio"},
    {"expect": "ROOM-DENSITY-SETUP:STUDIO"},
    {"sendline": "examine fireplace"},
    {"expect": "fireplace is cold and soot-darkened"},
    {"sendline": "rdchasm"},
    {"expect": "ROOM-DENSITY-SETUP:CHASM"},
    {"sendline": "examine path"},
    {"expect": "path hugs the eastern edge"},
    {"sendline": "rdpassage"},
    {"expect": "ROOM-DENSITY-SETUP:PASSAGE"},
    {"sendline": "examine opening"},
    {"expect": "roughly cyclops-shaped"},
    {"sendline": "rdtreasure"},
    {"expect": "ROOM-DENSITY-SETUP:TREASURE"},
    {"sendline": "search bags"},
    {"expect": "discarded bags are empty"},
    {"sendline": "rdpath"},
    {"expect": "ROOM-DENSITY-SETUP:PATH"},
    {"sendline": "examine path"},
    {"expect": "path is packed earth"},
    {"sendline": "rdreport"},
    {"expect": "ROOM-DENSITY-STATE:TROLL=SEEN;GALLERY=SEEN;STUDIO=SEEN;CHASM=SEEN;PASSAGE=SEEN;TREASURE=SEEN;PATH=SEEN"},
    {"sendline": "save"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{STATE_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "rdmutate"},
    {"expect": "ROOM-DENSITY-STATE:MUTATED"},
    {"sendline": "rdreport"},
    {"expect": "ROOM-DENSITY-STATE:TROLL=CLEAR;GALLERY=CLEAR;STUDIO=CLEAR;CHASM=CLEAR;PASSAGE=CLEAR;TREASURE=CLEAR;PATH=CLEAR"},
    {"sendline": "restore"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{STATE_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "rdreport"},
    {"expect": "ROOM-DENSITY-STATE:TROLL=SEEN;GALLERY=SEEN;STUDIO=SEEN;CHASM=SEEN;PASSAGE=SEEN;TREASURE=SEEN;PATH=SEEN"},
    {"sendline": "quit"},
    {"expect": "(?i)(really|wish to leave|are you sure)"},
    {"sendline": "yes"},
    {"expect_eof": true}
  ]
}
