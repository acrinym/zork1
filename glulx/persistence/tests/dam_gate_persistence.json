    {"expect": "PERSIST:DAM=INTERLOCKED-GATES-OPEN"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "persistdamtimer"},
    {"expect": "PERSIST:DAM-TIMER=COMPLETED"},
    {"sendline": "persistdammutate"},
    {"expect": "PERSIST-MUTATED:DAM"},
    {"sendline": "restore"},
    {"expect": "(?i)(file name|filename)"},
    {"sendline": "{SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "persistdamreport"},
    {"expect": "PERSIST:DAM=INTERLOCKED-GATES-OPEN"},
