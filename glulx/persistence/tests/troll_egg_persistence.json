{
  "timeout_seconds": 30,
  "allowed_exit_codes": [0],
  "close_stdin": false,
  "steps": [
    {"expect": "Release 1216"},
    {"sendline": "persisttrollready"},
    {"expect": "PERSIST-SETUP:TROLL-READY"},
    {"sendline": "tie up troll with rope"},
    {"expect": "The bound troll remains alive"},
    {"sendline": "persisttrollreport"},
    {"expect": "PERSIST:TROLL=BOUND-ROPE-COMMITTED-AXE-DROPPED-PASSAGES-OPEN"},
    {"sendline": "persisteggready"},
    {"expect": "PERSIST-SETUP:EGG-READY"},
    {"sendline": "put sack under tree"},
    {"expect": "prepared catcher|safety net"},
    {"sendline": "up"},
    {"expect": "Up a Tree"},
    {"sendline": "burn nest with torch"},
    {"expect": "lands in the prepared brown sack"},
    {"sendline": "persisteggreport"},
    {"expect": "PERSIST:EGG=INTACT-IN-PREPARED-SACK"},
    {"sendline": "save"},
    {"expect": "(?i)(file name|filename)"},
    {"sendline": "{SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "persisttrollmutate"},
    {"expect": "PERSIST-MUTATED:TROLL"},
    {"sendline": "persisteggmutate"},
    {"expect": "PERSIST-MUTATED:EGG"},
    {"sendline": "persisttrollreport"},
    {"expect": "PERSIST:TROLL=OTHER"},
    {"sendline": "persisteggreport"},
    {"expect": "PERSIST:EGG=OTHER"},
    {"sendline": "restore"},
    {"expect": "(?i)(file name|filename)"},
    {"sendline": "{SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "persisttrollreport"},
    {"expect": "PERSIST:TROLL=BOUND-ROPE-COMMITTED-AXE-DROPPED-PASSAGES-OPEN"},
    {"sendline": "persisteggreport"},
    {"expect": "PERSIST:EGG=INTACT-IN-PREPARED-SACK"},
    {"sendline": "persisttrollmutate"},
    {"expect": "PERSIST-MUTATED:TROLL"},
    {"sendline": "persisteggmutate"},
    {"expect": "PERSIST-MUTATED:EGG"},
    {"sendline": "restore"},
    {"expect": "(?i)(file name|filename)"},
    {"sendline": "{SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "persisttrollreport"},
    {"expect": "PERSIST:TROLL=BOUND-ROPE-COMMITTED-AXE-DROPPED-PASSAGES-OPEN"},
    {"sendline": "persisteggreport"},
    {"expect": "PERSIST:EGG=INTACT-IN-PREPARED-SACK"},
    {"sendline": "quit"},
    {"expect": "(?i)(really|wish to leave|are you sure)"},
    {"sendline": "yes"},
    {"expect_eof": true}
  ]
}
