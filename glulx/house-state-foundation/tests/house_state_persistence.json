{
  "timeout_seconds": 45,
  "allowed_exit_codes": [0],
  "close_stdin": false,
  "steps": [
    {"expect": "Release 1219"},
    {"sendline": "hsliving"},
    {"expect": "HOUSE-STATE-SETUP:LIVING"},
    {"sendline": "hskitchen"},
    {"expect": "HOUSE-STATE-SETUP:KITCHEN"},
    {"sendline": "hsattic"},
    {"expect": "HOUSE-STATE-SETUP:ATTIC"},
    {"sendline": "hscellar"},
    {"expect": "HOUSE-STATE-SETUP:CELLAR"},
    {"sendline": "hsreturn"},
    {"expect": "HOUSE-STATE-SETUP:RETURN"},
    {"sendline": "hscollect"},
    {"expect": "HOUSE-STATE-SETUP:COLLECTION"},
    {"sendline": "put painting in case"},
    {"expect": ">"},
    {"sendline": "move rug"},
    {"expect": "With a great effort, the rug is moved"},
    {"sendline": "open trap door"},
    {"expect": "The door reluctantly opens"},
    {"sendline": "hsreport"},
    {"expect": "HOUSE-STATE:VERSION=1;CONDITION=2;COLLECTION=1;KNOWLEDGE=2;SECURITY=2;ATMOSPHERE=2;ENTERED=Y;ATTIC=Y;CELLAR=Y;RETURN=Y;COLLECTED=Y;DISTURBED=Y"},
    {"sendline": "save"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{STATE_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "hsmutate"},
    {"expect": "HOUSE-STATE:MUTATED"},
    {"sendline": "hsreport"},
    {"expect": "HOUSE-STATE:VERSION=1;CONDITION=0;COLLECTION=0;KNOWLEDGE=0;SECURITY=0;ATMOSPHERE=0;ENTERED=N;ATTIC=N;CELLAR=N;RETURN=N;COLLECTED=N;DISTURBED=N"},
    {"sendline": "restore"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{STATE_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "hsreport"},
    {"expect": "HOUSE-STATE:VERSION=1;CONDITION=2;COLLECTION=1;KNOWLEDGE=2;SECURITY=2;ATMOSPHERE=2;ENTERED=Y;ATTIC=Y;CELLAR=Y;RETURN=Y;COLLECTED=Y;DISTURBED=Y"},
    {"sendline": "hsmigrate"},
    {"expect": "HOUSE-STATE:MIGRATED"},
    {"expect": "HOUSE-STATE:VERSION=1;CONDITION=2;COLLECTION=1;KNOWLEDGE=1;SECURITY=2;ATMOSPHERE=1;ENTERED=Y;ATTIC=Y;CELLAR=Y;RETURN=N;COLLECTED=Y;DISTURBED=Y"},
    {"sendline": "quit"},
    {"expect": "(?i)(really|wish to leave|are you sure)"},
    {"sendline": "yes"},
    {"expect_eof": true}
  ]
}
