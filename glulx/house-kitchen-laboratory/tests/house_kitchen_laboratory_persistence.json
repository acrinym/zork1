{
  "timeout_seconds": 60,
  "allowed_exit_codes": [
    0
  ],
  "close_stdin": false,
  "steps": [
    {"expect": "Release 1221"},
    {"sendline": "ksetup"},
    {"expect": "KITCHEN-SETUP:READY"},
    {"sendline": "wash knife in sink"},
    {"expect": "wash the nasty knife"},
    {"sendline": "dry knife"},
    {"expect": "dry the nasty knife thoroughly"},
    {"sendline": "put garlic on worktop"},
    {"expect": ">"},
    {"sendline": "slice garlic with knife"},
    {"expect": "slice the real clove"},
    {"sendline": "put lunch on worktop"},
    {"expect": ">"},
    {"sendline": "prepare lunch"},
    {"expect": "unwrap and arrange"},
    {"sendline": "open cupboard"},
    {"expect": ">"},
    {"sendline": "put garlic in cupboard"},
    {"expect": ">"},
    {"sendline": "put lunch in cupboard"},
    {"expect": ">"},
    {"sendline": "fill bottle from sink"},
    {"expect": "Cold water runs into the real glass bottle"},
    {"sendline": "wash wrench in sink"},
    {"expect": "removes the visible grime from the wrench"},
    {"sendline": "light range with torch"},
    {"expect": "transfer flame to the range"},
    {"sendline": "put wrench on range"},
    {"expect": ">"},
    {"sendline": "warm wrench on range"},
    {"expect": "controlled heat dries the wrench"},
    {"sendline": "take wrench"},
    {"expect": ">"},
    {"sendline": "put bottle on range"},
    {"expect": ">"},
    {"sendline": "warm bottle on range"},
    {"expect": "water becomes warm"},
    {"sendline": "kreport"},
    {"expect": "KITCHEN:VERSION=1;WATER-BOTTLE=Y;KNIFE-CLEAN=Y;KNIFE-WET=N;GARLIC-SLICED=Y;GARLIC-CUPBOARD=Y;LUNCH-PREP=Y;LUNCH-CUPBOARD=Y;WRENCH-CLEAN=Y;WRENCH-WET=N;RANGE-HOT=Y;WATER-WARM=Y;RESIDUE=Y;STORAGE=Y;RUST-WORSE=N"},
    {"sendline": "save"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{KITCHEN_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "kmutate"},
    {"expect": "KITCHEN:MUTATED"},
    {"sendline": "kreport"},
    {"expect": "KITCHEN:VERSION=1;WATER-BOTTLE=N;KNIFE-CLEAN=N;KNIFE-WET=N;GARLIC-SLICED=N;GARLIC-CUPBOARD=N;LUNCH-PREP=N;LUNCH-CUPBOARD=N;WRENCH-CLEAN=N;WRENCH-WET=N;RANGE-HOT=N;WATER-WARM=N;RESIDUE=N;STORAGE=N;RUST-WORSE=N"},
    {"sendline": "restore"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{KITCHEN_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "kreport"},
    {"expect": "KITCHEN:VERSION=1;WATER-BOTTLE=Y;KNIFE-CLEAN=Y;KNIFE-WET=N;GARLIC-SLICED=Y;GARLIC-CUPBOARD=Y;LUNCH-PREP=Y;LUNCH-CUPBOARD=Y;WRENCH-CLEAN=Y;WRENCH-WET=N;RANGE-HOT=Y;WATER-WARM=Y;RESIDUE=Y;STORAGE=Y;RUST-WORSE=N"},
    {"sendline": "take bottle"},
    {"expect": ">"},
    {"sendline": "use bottle on range"},
    {"expect": "Water flashes into steam"},
    {"sendline": "kreport"},
    {"expect": "KITCHEN:VERSION=1;WATER-BOTTLE=N;KNIFE-CLEAN=Y;KNIFE-WET=N;GARLIC-SLICED=Y;GARLIC-CUPBOARD=Y;LUNCH-PREP=Y;LUNCH-CUPBOARD=Y;WRENCH-CLEAN=Y;WRENCH-WET=N;RANGE-HOT=N;WATER-WARM=N;RESIDUE=Y;STORAGE=Y;RUST-WORSE=N"},
    {"sendline": "quit"},
    {"expect": "(?i)(really|wish to leave|are you sure)"},
    {"sendline": "yes"},
    {"expect_eof": true}
  ]
}
