{
  "timeout_seconds": 45,
  "allowed_exit_codes": [0],
  "close_stdin": false,
  "steps": [
    {"expect": "Release 1217"},
    {"sendline": "mpstart"},
    {"expect": "MATERIAL-PERSIST:START"},
    {"sendline": "use shovel on board"},
    {"expect": "work the shovel blade into the narrow seam"},
    {"sendline": "use screwdriver on board"},
    {"expect": "finds no screw head"},
    {"sendline": "mppath"},
    {"expect": "MATERIAL-PERSIST:PATH"},
    {"sendline": "use rope on railing"},
    {"expect": "tie one end of the rope securely to the wooden railing"},
    {"sendline": "use bottle on shovel"},
    {"expect": "rinse packed soil from the shovel blade"},
    {"sendline": "mrefil"},
    {"expect": "MATERIAL-SETUP:REFILL"},
    {"sendline": "use bottle on rusty knife"},
    {"expect": "Water carries loose orange rust from the knife"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"sendline": "wait"},
    {"expect": "A fresh orange bloom spreads along the blade"},
    {"sendline": "mrefil"},
    {"expect": "MATERIAL-SETUP:REFILL"},
    {"sendline": "mptree"},
    {"expect": "MATERIAL-PERSIST:TREE"},
    {"sendline": "use bottle on nest"},
    {"expect": "soak the woven nest"},
    {"sendline": "mpreport"},
    {"expect": "MATERIAL-PERSIST:ROPE=RAILING;SACK=OPEN;BOARDS=PRIED-HARDWARE;SHOVEL=CLEAN;RUST=WORSE;NEST=WET"},
    {"sendline": "save"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{STATE_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "mpmutate"},
    {"expect": "MATERIAL-PERSIST:MUTATED"},
    {"sendline": "mpreport"},
    {"expect": "MATERIAL-PERSIST:ROPE=FREE;SACK=OPEN;BOARDS=CLEAR;SHOVEL=DIRTY;RUST=OLD;NEST=DRY"},
    {"sendline": "restore"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{STATE_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "mpreport"},
    {"expect": "MATERIAL-PERSIST:ROPE=RAILING;SACK=OPEN;BOARDS=PRIED-HARDWARE;SHOVEL=CLEAN;RUST=WORSE;NEST=WET"},
    {"sendline": "mppath"},
    {"expect": "MATERIAL-PERSIST:PATH"},
    {"sendline": "south"},
    {"expect": "soaked nest has finally dried enough"},
    {"expect": "anchored rope reaches its useful limit"},
    {"sendline": "untie rope"},
    {"expect": "undo the knot around the wooden railing"},
    {"sendline": "use rope on brown sack"},
    {"expect": "cinch it tight"},
    {"sendline": "mpreport"},
    {"expect": "MATERIAL-PERSIST:ROPE=SACK;SACK=CINCHED;BOARDS=PRIED-HARDWARE;SHOVEL=CLEAN;RUST=WORSE;NEST=DRY"},
    {"sendline": "save"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{SACK_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "mpmutate"},
    {"expect": "MATERIAL-PERSIST:MUTATED"},
    {"sendline": "restore"},
    {"expect": "(?i)(file name|filename|saved game)"},
    {"sendline": "{SACK_SAVE_FILE}"},
    {"expect": ">"},
    {"sendline": "mpreport"},
    {"expect": "MATERIAL-PERSIST:ROPE=SACK;SACK=CINCHED;BOARDS=PRIED-HARDWARE;SHOVEL=CLEAN;RUST=WORSE;NEST=DRY"},
    {"sendline": "open brown sack"},
    {"expect": "rope is cinched around the sack's mouth"},
    {"sendline": "quit"},
    {"expect": "(?i)(really|wish to leave|are you sure)"},
    {"sendline": "yes"},
    {"expect_eof": true}
  ]
}
